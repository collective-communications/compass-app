{
  "name": "compass-app",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "tooling/*"
  ],
  "scripts": {
    "dev": "supabase start && bun run --filter @compass/web dev",
    "dev:web": "bun run --filter @compass/web dev",
    "dev:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:migrate": "supabase migration new",
    "db:gen-types": "supabase gen types typescript --local > packages/types/src/database.ts",
    "build": "bun run --filter @compass/web build",
    "lint": "eslint .",
    "typecheck": "tsc -b",
    "test": "bun test",
    "test:e2e": "echo 'e2e tests not yet configured'",
    "build-storybook": "echo 'storybook not yet configured'",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules tooling/*/node_modules"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3"
  }
}
