{
  "name": "compass-app",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "tooling/*",
    "e2e"
  ],
  "scripts": {
    "prepare": "scripts/install-hooks.sh",
    "dev": "bun run --filter @compass/web dev",
    "db:push": "supabase db push",
    "db:migrate": "supabase migration new",
    "db:gen-types": "supabase gen types typescript --project-id gscaczmrruzymzdpzohr > packages/types/src/database.ts",
    "db:seed": "bun run scripts/seed-dev.ts",
    "db:clean": "bun run scripts/seed-dev.ts --clean",
    "seed:export": "bun run scripts/export-seed.ts",
    "export-seed-answers": "bun run scripts/export-seed-answers.ts",
    "vault:seed": "bun run scripts/seed-vault.ts",
    "setup:vercel": "bun run scripts/setup-vercel.ts",
    "build": "bun run --filter @compass/web build",
    "compass:build": "bun run --filter @compass/web build",
    "validation:dev": "bun run --filter @compass/validation dev",
    "validation:build": "bun run --filter @compass/validation build",
    "validation:preview": "bun run --filter @compass/validation preview",
    "lint": "eslint .",
    "typecheck": "tsc -b",
    "test": "bun test apps/web packages",
    "test:e2e": "bun run --filter @compass/e2e test",
    "test:visual": "bun run --filter @compass/storybook test:visual",
    "test:storybook": "bun run --filter @compass/storybook test-storybook",
    "storybook": "bun run --filter @compass/storybook storybook",
    "build-storybook": "bun run --filter @compass/storybook build-storybook",
    "deploy-storybook": "scripts/deploy-storybook.sh",
    "deploy-validation": "scripts/deploy-validation.sh",
    "compass:start": "scripts/app-manager.sh start",
    "compass:stop": "scripts/app-manager.sh stop",
    "compass:restart": "scripts/app-manager.sh restart",
    "compass:status": "scripts/app-manager.sh status",
    "ci:watch": "scripts/ci-watch.sh",
    "push": "git push && scripts/ci-watch.sh",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules tooling/*/node_modules",
    "headless-smoke": "bun run scripts/headless-smoke.ts"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@compass/sdk": "workspace:*",
    "@compass/types": "workspace:*",
    "@happy-dom/global-registrator": "20.8.4",
    "@supabase/supabase-js": "^2.98.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.0.3",
    "happy-dom": "20.8.4",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "flatted": ">=3.4.0",
    "semver": "^7"
  }
}
