# Supabase (cloud)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase Admin (for seed scripts only — NEVER expose client-side)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
VITE_APP_URL=http://localhost:5173

# AWS SES (edge functions — set via `supabase secrets set`)
AWS_SES_ACCESS_KEY_ID=
AWS_SES_SECRET_ACCESS_KEY=
AWS_SES_REGION=us-east-1
SES_FROM_ADDRESS=noreply@collectivecommunication.ca

# OpenAI (edge functions — set via `supabase secrets set`)
OPENAI_API_KEY=
