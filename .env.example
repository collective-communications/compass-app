# Supabase (cloud)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase Admin (for seed scripts only — NEVER expose client-side)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
VITE_APP_URL=http://localhost:5173

# Resend (edge functions — set via `supabase secrets set`)
RESEND_API_KEY=re_xxxx  # RESEND_CCC_SEND key (send-only)
RESEND_FROM_ADDRESS=noreply@mail.collectiveculturecompass.com

# OpenAI (edge functions — set via `supabase secrets set`)
OPENAI_API_KEY=
