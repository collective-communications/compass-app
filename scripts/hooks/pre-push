#!/usr/bin/env bash
# Pre-push hook: run typecheck + tests before pushing to main.
# Bypass with: git push --no-verify

set -euo pipefail

while read -r local_ref local_sha remote_ref remote_sha; do
  if [[ "$remote_ref" == *"refs/heads/main"* ]]; then
    echo ""
    echo "Pre-push: running typecheck + tests before pushing to main..."
    echo "─────────────────────────────────────────────"
    echo ""

    if ! bun run typecheck; then
      echo ""
      echo "Typecheck failed. Push aborted."
      echo "Fix type errors or bypass with: git push --no-verify"
      exit 1
    fi

    if ! bun run test; then
      echo ""
      echo "Tests failed. Push aborted."
      echo "Fix failing tests or bypass with: git push --no-verify"
      exit 1
    fi

    echo ""
    echo "All checks passed."
    echo ""
  fi
done
